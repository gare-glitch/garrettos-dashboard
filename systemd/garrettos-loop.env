# /etc/garrettos-loop.env — environment for the GarrettOS Safe Loop Daemon.
# Copy to /etc/garrettos-loop.env and edit before `systemctl daemon-reload`.

# Colon-separated list of task directories to poll.
GARRETTOS_TASK_ROOTS=/root/vault/OpenClawMemory/tasks:/root/secondbrain/OpenClawMemory/tasks

# Where agent output logs are written.
GARRETTOS_LOG_DIR=/root/garrettos-logs

# Where per-task lock files live.
GARRETTOS_LOCK_DIR=/tmp/garrettos-locks

# Where blocked-task help entries are appended.
GARRETTOS_NEEDS_HELP_FILE=/root/NEEDS_HELP.md

# Poll interval in seconds.
GARRETTOS_POLL_INTERVAL=10

# Max runtime per task in seconds (0 = unlimited).
GARRETTOS_MAX_RUNTIME=0

# Root under which `repo:` target directories are resolved.
GARRETTOS_REPO_ROOT=/root
